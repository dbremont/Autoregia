begin-record
record object-content {
  content : { name: "x", active: true, nested: { k: null } };
}
end-record
---
begin-record
record scalar-content {
  content : 42;
  detail : true;
}
end-record
---
begin-record
record null-content {
  content : null;
}
end-record
